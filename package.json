{
  "name": "reactify",
  "version": "0.1.0",
  "description": "Fork of fastify-vite with React support",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "dist/index.d.ts",
      "import": "dist/index.js"
    },
    "./plugin": {
      "types": "dist/plugin.d.ts",
      "import": "dist/plugin.js"
    },
    "./client": {
      "types": "dist/client.d.ts",
      "import": "dist/client.js"
    },
    "./server": {
      "types": "dist/server.d.ts",
      "import": "dist/server.js"
    },
    "./utils": {
      "types": "dist/vite/utils.d.ts",
      "import": "dist/vite/utils.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/deepmerge": "^3.2.1",
    "@fastify/middie": "^9.3.2",
    "@fastify/static": "^9.1.2",
    "@unhead/react": "^2.1.13",
    "acorn": "^8.14.1",
    "acorn-strip-function": "^1.2.0",
    "acorn-walk": "^8.3.4",
    "devalue": "^5.8.1",
    "fastify-plugin": "^5.1.0",
    "fs-extra": "^11.3.4",
    "klaw": "^4.1.0",
    "minipass": "latest",
    "mlly": "^1.7.4",
    "package-directory": "^8.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.18.1",
    "valtio": "latest",
    "youch": "^3.3.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/klaw": "^3.0.7",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "fastify": "^5.8.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "fastify": ">=5",
    "vite": ">=6"
  }
}
